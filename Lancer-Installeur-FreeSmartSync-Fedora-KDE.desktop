#!/usr/bin/env xdg-open
[Desktop Entry]
Version=1.0
Type=Application
Name=Installer FreeSmartSync (Fedora/KDE)
Name[fr]=Installer FreeSmartSync (Fedora/KDE)
Comment=Ouvrez un terminal et lancez le script .sh — ou clic droit → Exécuter
Comment[fr]=Ouvrez un terminal et lancez le script .sh — ou clic droit → Exécuter
Exec=bash -c 'konsole -e bash "%k/../CLIC-DROIT-Executer-pour-installer-FreeSmartSync.sh" || xterm -e bash "%k/../CLIC-DROIT-Executer-pour-installer-FreeSmartSync.sh" || bash "%k/../CLIC-DROIT-Executer-pour-installer-FreeSmartSync.sh"'
Icon=system-software-install
Terminal=true
Categories=System;
StartupNotify=false
